{
  "__comment": "infra/phase14/grafana-dashboard-app.json — SampleAPI Application Performance Dashboard",
  "__comment2": "Import via OCP Console (Observe > Dashboards) or Grafana UI",
  "__comment3": "Uses Prometheus metrics from ServiceMonitor + kube-state-metrics + cAdvisor",
  "annotations": {
    "list": []
  },
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Application Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Available Replicas",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "kube_deployment_status_replicas_available{deployment=\"sampleapi\", namespace=~\"$namespace\"}",
          "legendFormat": "{{ namespace }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 2 }
            ]
          }
        }
      }
    },
    {
      "title": "Pod Restarts (last 1h)",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "targets": [
        {
          "expr": "sum(increase(kube_pod_container_status_restarts_total{container=\"sampleapi\", namespace=~\"$namespace\"}[1h]))",
          "legendFormat": "Restarts"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      }
    },
    {
      "title": "Request Rate (req/s)",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_received_total{job=\"sampleapi\", namespace=~\"$namespace\"}[5m]))",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "title": "Error Rate (%)",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_received_total{job=\"sampleapi\", namespace=~\"$namespace\", code=~\"5..\"}[5m])) / sum(rate(http_requests_received_total{job=\"sampleapi\", namespace=~\"$namespace\"}[5m])) * 100",
          "legendFormat": "Error %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "title": "P99 Latency",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"sampleapi\", namespace=~\"$namespace\"}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      }
    },
    {
      "title": "Uptime",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "targets": [
        {
          "expr": "min(time() - kube_pod_start_time{pod=~\"sampleapi.*\", namespace=~\"$namespace\"})",
          "legendFormat": "Uptime"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "HTTP Traffic",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "title": "Request Rate by Status Code",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_received_total{job=\"sampleapi\", namespace=~\"$namespace\"}[5m])) by (code)",
          "legendFormat": "{{ code }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "title": "Response Latency Distribution",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"sampleapi\", namespace=~\"$namespace\"}[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"sampleapi\", namespace=~\"$namespace\"}[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"sampleapi\", namespace=~\"$namespace\"}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Resource Usage",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "title": "CPU Usage by Pod",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{container=\"sampleapi\", namespace=~\"$namespace\"}[5m])) by (pod)",
          "legendFormat": "{{ pod }}"
        },
        {
          "expr": "sum(kube_pod_container_resource_limits{container=\"sampleapi\", namespace=~\"$namespace\", resource=\"cpu\"}) by (pod)",
          "legendFormat": "{{ pod }} limit"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "title": "Memory Usage by Pod",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{container=\"sampleapi\", namespace=~\"$namespace\"}) by (pod)",
          "legendFormat": "{{ pod }}"
        },
        {
          "expr": "sum(kube_pod_container_resource_limits{container=\"sampleapi\", namespace=~\"$namespace\", resource=\"memory\"}) by (pod)",
          "legendFormat": "{{ pod }} limit"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "title": "Network I/O",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "targets": [
        {
          "expr": "sum(rate(container_network_receive_bytes_total{pod=~\"sampleapi.*\", namespace=~\"$namespace\"}[5m])) by (pod)",
          "legendFormat": "{{ pod }} RX"
        },
        {
          "expr": "sum(rate(container_network_transmit_bytes_total{pod=~\"sampleapi.*\", namespace=~\"$namespace\"}[5m])) by (pod)",
          "legendFormat": "{{ pod }} TX"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    },
    {
      "title": "Pod Restart History",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "targets": [
        {
          "expr": "kube_pod_container_status_restarts_total{container=\"sampleapi\", namespace=~\"$namespace\"}",
          "legendFormat": "{{ pod }}"
        }
      ]
    }
  ],
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["devsecops", "sampleapi", "application"],
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(kube_deployment_status_replicas{deployment=\"sampleapi\"}, namespace)",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "SampleAPI - Application Performance",
  "uid": "sampleapi-app-perf",
  "version": 1
}
